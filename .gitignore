# =============================================================================
# BUILDABLE BACKEND — .gitignore
# =============================================================================

# ── Environment / Secrets (NEVER commit these) ────────────────────────────────
.env
.env.local
.env.production
.env.staging
*.env

# ── Build output ──────────────────────────────────────────────────────────────
dist/
build/

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
bun.lockb

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ── Runtime ───────────────────────────────────────────────────────────────────
pids/
*.pid
*.pid.lock

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.sw?
