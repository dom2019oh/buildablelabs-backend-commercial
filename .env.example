# =============================================================================
# BUILDABLE BACKEND ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=3000
VERSION=1.0.0
CORS_ORIGINS=http://localhost:5173,https://buildablelabs.dev,https://www.buildablelabs.dev,https://dashboard.buildablelabs.dev

# =============================================================================
# FIREBASE ADMIN (Required — for verifying Firebase Auth tokens)
# =============================================================================
FIREBASE_PROJECT_ID=buildablelabs-42259
# Base64-encoded service account JSON
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("serviceAccountKey.json"))
FIREBASE_SERVICE_ACCOUNT_KEY=base64-encoded-service-account-json

# =============================================================================
# AI PROVIDERS (At least one required)
# =============================================================================
# OpenAI — active now
OPENAI_API_KEY=sk-your-openai-key

# Anthropic — add when credits arrive
ANTHROPIC_API_KEY=your-anthropic-key

# Default AI configuration
DEFAULT_AI_PROVIDER=openai
DEFAULT_ARCHITECT_MODEL=gpt-4o
DEFAULT_CODER_MODEL=gpt-4o

# =============================================================================
# PREVIEW SERVER
# =============================================================================
PREVIEW_BASE_PORT=3100
PREVIEW_HOST=localhost
PREVIEW_MAX_SERVERS=10

# =============================================================================
# QUEUE (Optional)
# =============================================================================
# REDIS_URL=redis://localhost:6379

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# STRIPE (Required for paid plans)
# =============================================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Redirect base after checkout (no trailing slash)
STRIPE_REDIRECT_BASE=https://dashboard.buildablelabs.dev

# Stripe Price IDs — create one product per tier in Stripe dashboard
# Pro tiers (30 credits = $18, +30 credits = +$14/mo)
STRIPE_PRICE_PRO_T1=price_...
STRIPE_PRICE_PRO_T2=price_...
STRIPE_PRICE_PRO_T3=price_...
STRIPE_PRICE_PRO_T4=price_...
STRIPE_PRICE_PRO_T5=price_...
STRIPE_PRICE_PRO_T6=price_...
STRIPE_PRICE_PRO_T7=price_...
STRIPE_PRICE_PRO_T8=price_...
STRIPE_PRICE_PRO_T9=price_...
STRIPE_PRICE_PRO_T10=price_...
# Max tiers (100 credits = $59, +100 credits = +$40/mo)
STRIPE_PRICE_MAX_T1=price_...
STRIPE_PRICE_MAX_T2=price_...
STRIPE_PRICE_MAX_T3=price_...
STRIPE_PRICE_MAX_T4=price_...
STRIPE_PRICE_MAX_T5=price_...
STRIPE_PRICE_MAX_T6=price_...
STRIPE_PRICE_MAX_T7=price_...
STRIPE_PRICE_MAX_T8=price_...
STRIPE_PRICE_MAX_T9=price_...
STRIPE_PRICE_MAX_T10=price_...
