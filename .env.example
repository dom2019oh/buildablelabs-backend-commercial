# =============================================================================
# BUILDABLE BACKEND ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=3000
VERSION=1.0.0
CORS_ORIGINS=http://localhost:5173,https://buildablelabs.dev,https://www.buildablelabs.dev

# =============================================================================
# SUPABASE (Required)
# =============================================================================
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# =============================================================================
# AI PROVIDERS (At least one required)
# =============================================================================
# Anthropic — Claude (primary, recommended for Discord bot generation)
ANTHROPIC_API_KEY=your-anthropic-key

# OpenAI (fallback — used automatically if ANTHROPIC_API_KEY is not set)
OPENAI_API_KEY=sk-your-openai-key

# Google AI (optional)
GOOGLE_AI_KEY=your-google-ai-key

# Default AI configuration
# Provider auto-selects Claude when ANTHROPIC_API_KEY is present
DEFAULT_AI_PROVIDER=anthropic
DEFAULT_ARCHITECT_MODEL=claude-sonnet-4-6
DEFAULT_CODER_MODEL=claude-sonnet-4-6

# =============================================================================
# PREVIEW SERVER
# =============================================================================
PREVIEW_BASE_PORT=3100
PREVIEW_HOST=localhost
PREVIEW_MAX_SERVERS=10

# =============================================================================
# QUEUE (Optional - for scalability)
# =============================================================================
# Redis URL for job queue (optional - direct execution if not set)
REDIS_URL=redis://localhost:6379

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=debug
